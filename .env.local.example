# Dataghmart Data Bundles — Environment Variables Template
# Copy this to .env.local and fill in your actual values

# ─── DataMart API ────────────────────────────────────────────────
# ALL data operations and payments go through DataMart API.
# Get your API key from https://datamartgh.shop
DATAMART_API_KEY=ask_your_datamart_api_key_here
DATAMART_API_BASE_URL=https://api.datamartgh.shop/api/store/v1
DATAMART_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# ─── NextAuth ────────────────────────────────────────────────────
# Required for Google sign-in and session management
NEXTAUTH_SECRET=your_nextauth_secret_here
NEXTAUTH_URL=https://dataghmart.vercel.app

# ─── Google OAuth ────────────────────────────────────────────────
# Get from https://console.cloud.google.com/apis/credentials
# Both must be set for Google sign-in to work
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ─── App ─────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://dataghmart.vercel.app
NEXT_PUBLIC_APP_NAME=Dataghmart Data Bundles

# ─── Admin ───────────────────────────────────────────────────────
ADMIN_SECRET=your_admin_secret_here

# ─── Database (SQLite — no external DB needed) ───────────────────
DATABASE_URL=file:./../db/databundles.db
